<style>
@import url('https://fonts.googleapis.com/css2?family=Exo+2:wght@500;700;800&family=Inter:wght@400;500;600;700&display=swap');
:root{
  --bg:#0b0d12;--s1:#131722;--s2:#181d29;--s3:#1e2334;
  --border:rgba(255,255,255,.08);--border2:rgba(255,255,255,.13);
  --text:#edf1f7;--muted:#9da7bc;--faint:#4e566a;
  --gold:#f3c55a;--teal:#5bd9d0;--green:#6fe28b;--red:#ff6b6b;--orange:#ff9966;
  --r:20px;--sh:0 8px 32px rgba(0,0,0,.3);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:radial-gradient(ellipse at top,#171d2b,#0b0d12 60%);min-height:100vh;color:var(--text);font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased}
button,input,select{font:inherit;color:inherit}button{cursor:pointer}input,select{cursor:text}
.app{max-width:460px;margin:0 auto;padding:16px 14px 48px}
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.brand{font-family:'Exo 2',sans-serif;font-size:19px;font-weight:800;display:flex;align-items:center;gap:8px}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--faint);transition:background .3s}
.sync-dot.ok{background:var(--green)}
.sync-dot.syncing{background:var(--gold);animation:pulse .8s infinite}
.sync-dot.err{background:var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.tbr{display:flex;gap:8px}
.icobtn{width:40px;height:40px;border-radius:13px;border:1px solid var(--border);background:var(--s1);color:var(--text);display:flex;align-items:center;justify-content:center;font-size:17px}
.icobtn:hover{background:var(--s2)}
/* activation */
.act-screen{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;text-align:center}
.act-logo{font-size:64px;margin-bottom:20px}
.act-title{font-family:'Exo 2',sans-serif;font-size:26px;font-weight:800;margin-bottom:8px}
.act-sub{font-size:13px;color:var(--muted);margin-bottom:32px;line-height:1.6}
.act-input{width:100%;padding:16px;border-radius:14px;background:var(--s2);border:1px solid var(--border);color:var(--text);font-size:17px;font-weight:700;text-align:center;letter-spacing:2px;margin-bottom:12px}
.act-input:focus{outline:none;border-color:rgba(243,197,90,.5)}
.act-input.error{border-color:rgba(255,107,107,.5);animation:shake .3s}
.act-error{font-size:12px;color:var(--red);min-height:16px;margin-bottom:12px}
.act-btn{width:100%;padding:15px;border:none;border-radius:13px;background:var(--gold);color:#111;font-size:16px;font-weight:800;font-family:'Exo 2',sans-serif}
.act-loading{font-size:13px;color:var(--muted);margin-top:12px}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
/* start screen */
.start-screen{text-align:center;padding:48px 24px}
.start-title{font-family:'Exo 2',sans-serif;font-size:28px;font-weight:800;margin-bottom:8px}
.start-sub{font-size:14px;color:var(--muted);margin-bottom:32px;line-height:1.6}
.start-dur{display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:24px}
.start-dur label{font-size:13px;color:var(--muted)}
.start-dur input{width:72px;padding:10px;border-radius:12px;background:var(--s2);border:1px solid var(--border);color:var(--text);text-align:center;font-size:16px;font-weight:700}
.btn-start{width:100%;padding:18px;border:none;border-radius:16px;background:var(--gold);color:#111;font-size:18px;font-weight:800;font-family:'Exo 2',sans-serif}
.chal-bar{padding:12px 14px;border:1px solid rgba(91,217,208,.22);border-radius:16px;background:rgba(91,217,208,.06);margin-bottom:12px}
.chal-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.chal-title{font-size:13px;font-weight:700;color:var(--teal)}
.chal-dates{font-size:12px;color:var(--muted)}
.prog-track{height:7px;border-radius:999px;background:rgba(255,255,255,.06);overflow:hidden;margin-bottom:6px}
.prog-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--teal),#a0ede9)}
.chal-foot{display:flex;justify-content:space-between;font-size:12px;color:var(--muted)}
.chal-reset{font-size:11px;color:var(--faint);background:none;border:none;padding:0;cursor:pointer;text-decoration:underline}
.hero{padding:16px;border:1px solid var(--border);border-radius:var(--r);background:linear-gradient(160deg,rgba(243,197,90,.1),rgba(255,255,255,.02));box-shadow:var(--sh);display:grid;grid-template-columns:88px 1fr;gap:14px;align-items:start;margin-bottom:12px}
.av-wrap{display:flex;flex-direction:column;align-items:center;gap:8px}
.av{width:84px;height:84px;border-radius:24px;background:linear-gradient(135deg,#252e46,#161b28);border:1px solid rgba(243,197,90,.22);display:flex;align-items:center;justify-content:center;overflow:hidden;font-size:40px}
.av img{width:100%;height:100%;object-fit:cover}
.av-sub{font-size:11px;color:var(--muted)}
.hero-r{display:flex;flex-direction:column;gap:8px}
.hname{font-family:'Exo 2',sans-serif;font-size:21px;font-weight:800;line-height:1.1}
.rank-row{display:flex;align-items:center;justify-content:space-between;gap:6px;flex-wrap:wrap}
.rank{padding:6px 11px;border-radius:999px;font-size:11px;font-weight:700;border:1px solid}
.xp-total{font-family:'Exo 2',sans-serif;font-size:21px;font-weight:800;color:var(--gold)}
.bar-track{height:8px;border-radius:999px;background:rgba(255,255,255,.06);overflow:hidden}
.bar-fill{height:100%;border-radius:999px}
.next-row{display:flex;justify-content:space-between;font-size:11px;color:var(--muted)}
.stats4{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.scard{padding:12px 8px;text-align:center;border:1px solid var(--border);border-radius:16px;background:var(--s1)}
.sv{font-family:'Exo 2',sans-serif;font-size:19px;font-weight:800}
.sl{font-size:10px;color:var(--muted);margin-top:3px;line-height:1.3}
.sec{margin-bottom:12px}
.sec-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;padding:0 2px}
.sec-title{font-family:'Exo 2',sans-serif;font-size:12px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:var(--muted)}
.sec-sub{font-size:12px;color:var(--muted)}
.task-list{display:flex;flex-direction:column;gap:8px;padding:10px;border:1px solid var(--border);border-radius:var(--r);background:var(--s1)}
.task-item{display:flex;align-items:center;padding:12px;border:1px solid var(--border);border-radius:14px;background:var(--s2);gap:10px}
.task-item.done{border-color:rgba(243,197,90,.35);background:rgba(243,197,90,.07)}
.task-cb{background:none;border:none;padding:0;display:flex;align-items:center;flex:1;gap:10px;text-align:left;cursor:pointer}
.task-txt{display:flex;flex-direction:column;gap:3px}
.task-name{font-size:14px;font-weight:600;color:#edf1f7}
.task-meta{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.task-streak-badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:rgba(255,153,102,.15);color:var(--orange);border:1px solid rgba(255,153,102,.25)}
.task-streak-badge.on{background:rgba(255,153,102,.25);border-color:rgba(255,153,102,.5)}
.check{width:26px;height:26px;border-radius:9px;border:2px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.task-item.done .check{background:var(--gold);border-color:var(--gold);color:#111}
.num-inp{width:66px;padding:8px;border-radius:12px;background:#0d1017;border:1px solid var(--border);color:#edf1f7;text-align:center;font-weight:600;font-size:14px;flex-shrink:0}
.num-inp:focus{outline:none;border-color:rgba(243,197,90,.4)}
.xp-box{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-radius:14px;background:rgba(243,197,90,.08);border:1px solid rgba(243,197,90,.18);margin-top:8px}
.xp-earned{font-family:'Exo 2',sans-serif;font-size:22px;font-weight:800;color:var(--gold)}
.chips{display:flex;gap:6px;flex-wrap:wrap}
.chip{padding:5px 9px;border-radius:9px;background:var(--s2);border:1px solid var(--border);font-size:11px;color:var(--muted)}
.streak-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.streak-card{padding:13px 14px;border:1px solid var(--border);border-radius:16px;background:var(--s1)}
.sc-label{font-size:10px;text-transform:uppercase;letter-spacing:.7px;color:var(--muted);margin-bottom:6px}
.sc-val{font-family:'Exo 2',sans-serif;font-size:20px;font-weight:800}
.sc-sub{font-size:11px;color:var(--muted);margin-top:2px}
.level-list{display:flex;flex-direction:column;gap:7px;padding:10px;border:1px solid var(--border);border-radius:var(--r);background:var(--s1)}
.level-row{display:flex;align-items:center;justify-content:space-between;padding:11px 12px;border:1px solid var(--border);border-radius:13px;background:var(--s2)}
.level-row.active-lv{border-color:rgba(243,197,90,.3);background:rgba(243,197,90,.07)}
.lv-name{font-size:13px;font-weight:700}
.lv-range{font-size:11px;color:var(--muted)}
.lv-remain{font-size:11px;color:var(--muted);text-align:right}
.days-toggle{width:100%;display:flex;align-items:center;justify-content:space-between;padding:13px 14px;border:1px solid var(--border);border-radius:16px;background:var(--s1);color:var(--text);text-align:left}
.dt-left{display:flex;flex-direction:column;gap:3px}
.dt-title{font-size:13px;font-weight:700;color:#edf1f7}
.dt-sub{font-size:11px;color:var(--muted)}
.dt-right{display:flex;align-items:center;gap:8px;flex-shrink:0}
.arrow{font-size:14px;color:var(--muted);transition:transform .25s;display:inline-block}
.arrow.open{transform:rotate(180deg)}
.days-wrap{margin-top:8px}
.days-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:7px}
.day-cell{padding:9px 5px;background:var(--s1);border:1px solid var(--border);border-radius:16px;text-align:center}
.day-cell.is-today{border-color:rgba(243,197,90,.3);background:rgba(243,197,90,.05)}
.dc-wd{font-size:9px;color:var(--muted);margin-bottom:5px;text-transform:uppercase}
.dc-dt{font-size:9px;color:var(--faint);margin-top:3px}
.dc-xp{font-size:9px;color:var(--muted);margin-top:1px}
.overlay{position:fixed;inset:0;background:rgba(7,9,14,.7);backdrop-filter:blur(8px);display:none;align-items:flex-end;justify-content:center;padding:12px;z-index:50}
.overlay.show{display:flex}
.sheet{max-width:460px;width:100%;max-height:90vh;overflow-y:auto;background:#0f1320;border:1px solid var(--border2);border-radius:26px;padding:18px}
.sh-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.sh-title{font-family:'Exo 2',sans-serif;font-size:20px;font-weight:800}
.grp{padding:13px;background:var(--s1);border:1px solid var(--border);border-radius:18px;margin-bottom:10px}
.grp-title{font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);font-weight:700;margin-bottom:10px}
.field{display:flex;flex-direction:column;gap:5px;margin-bottom:9px}
.field:last-child{margin-bottom:0}
.field label{font-size:12px;color:var(--muted)}
.inp{width:100%;padding:10px 12px;border-radius:12px;background:#0a0e17;border:1px solid var(--border);color:#edf1f7}
.inp:focus{outline:none;border-color:rgba(243,197,90,.4)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.mini{padding:9px 11px;border-radius:11px;background:var(--s2);border:1px solid var(--border);color:var(--text);font-size:13px;font-weight:600;white-space:nowrap}
.mini:hover{background:var(--s3)}
.del{padding:9px 11px;border-radius:11px;background:rgba(255,107,107,.1);border:1px solid rgba(255,107,107,.18);color:#ffb5b5;font-size:13px}
.tog{padding:7px 11px;border-radius:11px;font-size:11px;font-weight:700;border:1px solid;cursor:pointer}
.tog.on{background:rgba(111,226,139,.15);border-color:rgba(111,226,139,.35);color:var(--green)}
.tog.off{background:rgba(255,255,255,.04);border-color:var(--border);color:var(--muted)}
.btn-p{width:100%;padding:13px;border:none;border-radius:13px;background:var(--gold);color:#111;font-size:15px;font-weight:700}
.btn-s{width:100%;padding:13px;border:1px solid var(--border);border-radius:13px;background:var(--s2);color:var(--text);font-size:15px;font-weight:700}
.btn-d{width:100%;padding:13px;border:1px solid rgba(255,107,107,.2);border-radius:13px;background:rgba(255,107,107,.1);color:#ffb5b5;font-size:15px;font-weight:700}
.g2btn{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.save-bar{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px;position:sticky;bottom:0;padding:10px 0 4px;background:#0f1320}
.notice{font-size:12px;color:var(--muted);text-align:center;min-height:16px;margin-top:8px}
.dur-box{padding:11px;border-radius:12px;background:rgba(243,197,90,.08);border:1px solid rgba(243,197,90,.18);font-size:13px;font-weight:600;color:var(--gold);text-align:center;margin-top:8px;min-height:40px;display:flex;align-items:center;justify-content:center}
.hint{font-size:11px;color:var(--faint);margin-top:6px;line-height:1.5}
.task-edit-row{display:grid;grid-template-columns:24px 1fr 64px 48px auto auto;gap:6px;align-items:center;margin-bottom:6px;padding:8px;border-radius:12px;background:var(--s2);border:1px solid var(--border)}
.task-edit-row.dragging{opacity:.4}
.drag-handle{color:var(--faint);font-size:16px;cursor:grab;user-select:none;text-align:center}
.drag-handle:active{cursor:grabbing}
.lv-edit-row{display:grid;grid-template-columns:1fr 44px auto;gap:6px;align-items:center;margin-bottom:6px}
.lv-auto-badge{font-size:10px;color:var(--teal);background:rgba(91,217,208,.1);border:1px solid rgba(91,217,208,.2);border-radius:8px;padding:2px 8px;display:inline-block;margin-bottom:8px}
.rule-row{display:grid;grid-template-columns:1fr 1fr auto;gap:6px;align-items:center;margin-bottom:6px}
footer{padding:20px 0 4px;text-align:center;color:var(--faint);font-size:11px}
@media(max-width:380px){.stats4{grid-template-columns:repeat(2,1fr)}.hero{grid-template-columns:76px 1fr}.av{width:72px;height:72px;font-size:34px}.days-grid{grid-template-columns:repeat(4,1fr)}.task-edit-row{grid-template-columns:24px 1fr 56px 40px auto auto}}
</style>
</head>
<body>
<div class="app" id="app"></div>

<div class="overlay" id="calOverlay">
  <div class="sheet">
    <div class="sh-head"><div class="sh-title">🗓 Челлендж</div><button class="icobtn" id="calClose">✕</button></div>
    <div class="grp">
      <div class="grp-title">Период</div>
      <div class="g2">
        <div class="field"><label>Начало</label><input class="inp" type="date" id="calStart"></div>
        <div class="field"><label>Конец</label><input class="inp" type="date" id="calEnd"></div>
      </div>
      <div class="dur-box" id="calDur">Выбери даты</div>
    </div>
    <div class="g2btn" style="margin-top:4px">
      <button class="btn-s" id="calCancel">Отмена</button>
      <button class="btn-p" id="calSave">Сохранить</button>
    </div>
  </div>
</div>

<div class="overlay" id="setOverlay">
  <div class="sheet">
    <div class="sh-head"><div class="sh-title">Настройки</div><button class="icobtn" id="setClose">✕</button></div>
    <div class="grp">
      <div class="grp-title">Профиль</div>
      <div class="field"><label>Название трекера</label><input class="inp" id="cfgTitle"></div>
      <div class="field"><label>Имя персонажа</label><input class="inp" id="cfgName"></div>
      <div class="g2">
        <div class="field"><label>Аватар-эмодзи</label><input class="inp" id="cfgEmoji" maxlength="4"></div>
        <div class="field"><label>Цель XP в день</label><input class="inp" type="number" min="1" id="cfgGoal"></div>
      </div>
      <div class="field"><label>Фото аватара</label><input class="inp" type="file" accept="image/*" id="cfgPhoto"></div>
    </div>
    <div class="grp">
      <div class="grp-title">Штрафы и стрик</div>
      <div class="g2">
        <div class="field"><label>Штраф за пропуск</label><input class="inp" type="number" id="cfgPenalty"></div>
        <div class="field"><label>Мин. XP для стрика</label><input class="inp" type="number" id="cfgThreshold"></div>
      </div>
      <div class="hint">Штраф = за каждый прошлый день с 0 XP. Стрик считается если набрано ≥ порога подряд.</div>
    </div>
    <div class="grp">
      <div class="grp-title">Бонусы за стрик</div>
      <div id="rulesUI"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:8px;align-items:end;margin-top:8px">
        <div class="field"><label>Дней подряд</label><input class="inp" type="number" id="nrDays" value="7" min="1"></div>
        <div class="field"><label>Бонус XP</label><input class="inp" type="number" id="nrBonus" value="15" min="1"></div>
        <button class="mini" id="addRuleBtn" style="margin-top:22px">+</button>
      </div>
    </div>
    <div class="grp">
      <div class="grp-title">Задания <span style="color:var(--faint);font-size:10px;font-weight:400;text-transform:none">· перетащи чтобы изменить порядок</span></div>
      <div id="tasksUI"></div>
      <div style="display:grid;grid-template-columns:1fr 64px 48px auto auto;gap:6px;align-items:end;margin-top:10px">
        <div class="field"><label>Название</label><input class="inp" id="ntName"></div>
        <div class="field"><label>Тип</label><select class="inp" id="ntType"><option value="checkbox">Чек</option><option value="number">Число</option></select></div>
        <div class="field"><label>XP</label><input class="inp" type="number" id="ntXP" value="3" min="1"></div>
        <div class="field"><label>Стрик</label><button class="tog on" id="ntStreakTog" onclick="this.classList.toggle('on');this.classList.toggle('off');this.textContent=this.classList.contains('on')?'🔥':'—'">🔥</button></div>
        <button class="mini" id="addTaskBtn" style="margin-top:22px">+</button>
      </div>
    </div>
    <div class="grp">
      <div class="grp-title">Уровни</div>
      <div class="lv-auto-badge">Пороги XP считаются автоматически</div>
      <div id="levelsUI"></div>
      <div class="hint" id="lvHint"></div>
    </div>
    <div class="grp">
      <div class="grp-title">Данные</div>
      <button class="btn-d" id="resetBtn">Сбросить все данные</button>
      <div class="hint" style="text-align:center;margin-top:8px">Данные синхронизируются в облаке по твоему коду активации</div>
    </div>
    <div class="save-bar">
      <button class="btn-s" id="cancelSet">Отмена</button>
      <button class="btn-p" id="saveSet">Сохранить</button>
    </div>
    <div class="notice" id="setNotice"></div>
  </div>
</div>

<script>
// ── SUPABASE ───────────────────────────────────────────────────────────────
