    </div>
    <div class="sec">
      <div class="sec-head"><div class="sec-title">История</div><div class="sec-sub">с ${S.challenge.start} · ${hDays.length} дн.</div></div>
      <button class="days-toggle" id="daysToggle">
        <div class="dt-left"><div class="dt-title">Статистика по дням</div><div class="dt-sub">Сегодня ${todayBase} XP · ${todayPct}% от цели (${n(S.goal)} XP)</div></div>
        <div class="dt-right">${ring(todayPct,todayColor,46)}<span class="arrow${daysOpen?' open':''}" id="daysArrow">▼</span></div>
      </button>
      <div class="days-wrap" id="daysWrap" style="display:${daysOpen?'block':'none'}"><div class="days-grid">${daysHTML}</div></div>
    </div>
    <footer>Данные синхронизируются в облаке по коду активации</footer>`;

  document.querySelectorAll('[data-toggle]').forEach(b=>b.onclick=()=>{S.entries[td][b.dataset.toggle]=!S.entries[td][b.dataset.toggle];save();render();});
  document.querySelectorAll('[data-number]').forEach(inp=>inp.oninput=e=>{S.entries[td][inp.dataset.number]=n(e.target.value);save();render();});
  document.getElementById('daysToggle').onclick=()=>{daysOpen=!daysOpen;document.getElementById('daysWrap').style.display=daysOpen?'block':'none';document.getElementById('daysArrow').className='arrow'+(daysOpen?' open':'');};
  document.getElementById('calBtn').onclick=openCal;
  document.getElementById('setBtn').onclick=openSet;
  document.getElementById('resetChal').onclick=()=>{if(confirm('Сбросить челлендж?')){S.challenge=null;S.entries={};save();render();}};
}

// ── CALENDAR ───────────────────────────────────────────────────────────────
function openCal(){const td=today();document.getElementById('calStart').value=S.challenge?.start||td;if(!S.challenge){const d=new Date(td+'T12:00:00');d.setDate(d.getDate()+21);document.getElementById('calEnd').value=toISO(d);}else document.getElementById('calEnd').value=S.challenge.end;updCalDur();document.getElementById('calOverlay').classList.add('show');}
function updCalDur(){const s=document.getElementById('calStart').value,e=document.getElementById('calEnd').value,el=document.getElementById('calDur');if(!s||!e){el.textContent='Выбери даты';return;}const days=Math.round((new Date(e+'T12:00:00')-new Date(s+'T12:00:00'))/DAY)+1;if(days<=0){el.textContent='⚠️ Конец раньше начала';return;}el.textContent=`📅 ${days} дней  ·  ${s} → ${e}`;}
document.getElementById('calStart').oninput=updCalDur;
document.getElementById('calEnd').oninput=updCalDur;
function closeCal(){document.getElementById('calOverlay').classList.remove('show');}
document.getElementById('calClose').onclick=closeCal;
document.getElementById('calCancel').onclick=closeCal;
document.getElementById('calOverlay').onclick=e=>{if(e.target.id==='calOverlay')closeCal();};
document.getElementById('calSave').onclick=()=>{const s=document.getElementById('calStart').value,e=document.getElementById('calEnd').value;if(!s||!e)return;if(Math.round((new Date(e+'T12:00:00')-new Date(s+'T12:00:00'))/DAY)<0)return;S.challenge={start:s,end:e};Object.keys(S.entries).forEach(k=>{if(k<s)delete S.entries[k];});save();closeCal();render();};

// ── SETTINGS ───────────────────────────────────────────────────────────────
function openSet(){openDraft();document.getElementById('cfgTitle').value=draft.title;document.getElementById('cfgName').value=draft.name;document.getElementById('cfgEmoji').value=draft.emoji||'';document.getElementById('cfgGoal').value=draft.goal;document.getElementById('cfgPenalty').value=draft.penalty;document.getElementById('cfgThreshold').value=draft.threshold;rebuildRules();rebuildTasks();rebuildLevels();document.getElementById('setOverlay').classList.add('show');}
function closeSet(){document.getElementById('setOverlay').classList.remove('show');}
document.getElementById('setClose').onclick=()=>{discardDraft();closeSet();};
document.getElementById('cancelSet').onclick=()=>{discardDraft();closeSet();};
document.getElementById('saveSet').onclick=()=>{draft.title=document.getElementById('cfgTitle').value;draft.name=document.getElementById('cfgName').value;draft.emoji=document.getElementById('cfgEmoji').value;draft.goal=Math.max(1,n(document.getElementById('cfgGoal').value));draft.penalty=n(document.getElementById('cfgPenalty').value);draft.threshold=n(document.getElementById('cfgThreshold').value);applyDraft();closeSet();};
document.getElementById('setOverlay').onclick=e=>{if(e.target.id==='setOverlay'){discardDraft();closeSet();}};
function note(msg){const el=document.getElementById('setNotice');el.textContent=msg;setTimeout(()=>{if(el.textContent===msg)el.textContent='';},2200);}
document.getElementById('cfgPhoto').onchange=e=>{const f=e.target.files?.[0];if(!f)return;const r=new FileReader();r.onload=ev=>{S.photo=ev.target.result;save();render();note('Фото обновлено');};r.readAsDataURL(f);};

function rebuildRules(){const ui=document.getElementById('rulesUI');ui.innerHTML=[...draft.streakRules].sort((a,b)=>a.days-b.days).map(r=>`<div class="rule-row"><input class="inp" type="number" value="${r.days}" data-rd="${r.id}"><input class="inp" type="number" value="${r.bonus}" data-rb="${r.id}"><button class="del" data-rr="${r.id}">✕</button></div>`).join('');ui.querySelectorAll('[data-rd]').forEach(el=>el.oninput=e=>{draft.streakRules.find(r=>r.id===el.dataset.rd).days=n(e.target.value);});ui.querySelectorAll('[data-rb]').forEach(el=>el.oninput=e=>{draft.streakRules.find(r=>r.id===el.dataset.rb).bonus=n(e.target.value);});ui.querySelectorAll('[data-rr]').forEach(el=>el.onclick=()=>{draft.streakRules=draft.streakRules.filter(r=>r.id!==el.dataset.rr);rebuildRules();});}
document.getElementById('addRuleBtn').onclick=()=>{const d=n(document.getElementById('nrDays').value),b=n(document.getElementById('nrBonus').value);if(!d||!b)return note('Заполни поля');draft.streakRules.push({id:uid(),days:d,bonus:b});rebuildRules();};

function rebuildTasks(){
  const ui=document.getElementById('tasksUI');
  ui.innerHTML=draft.tasks.map(t=>`<div class="task-edit-row" data-drag-id="${t.id}"><div class="drag-handle">⠿</div><input class="inp" value="${esc(t.name)}" data-tn="${t.id}"><select class="inp" data-tt="${t.id}"><option value="checkbox"${t.type==='checkbox'?' selected':''}>Чек</option><option value="number"${t.type==='number'?' selected':''}>Число</option></select><input class="inp" type="number" value="${t.xp}" min="1" data-tx="${t.id}"><button class="tog ${t.streak?'on':'off'}" data-ts="${t.id}">${t.streak?'🔥':'—'}</button><button class="del" data-tr="${t.id}">✕</button></div>`).join('');
  ui.querySelectorAll('[data-tn]').forEach(el=>el.oninput=e=>{draft.tasks.find(t=>t.id===el.dataset.tn).name=e.target.value;rebuildLevels();});
  ui.querySelectorAll('[data-tt]').forEach(el=>el.onchange=e=>{draft.tasks.find(t=>t.id===el.dataset.tt).type=e.target.value;});
  ui.querySelectorAll('[data-tx]').forEach(el=>el.oninput=e=>{draft.tasks.find(t=>t.id===el.dataset.tx).xp=n(e.target.value);rebuildLevels();});
  ui.querySelectorAll('[data-ts]').forEach(el=>el.onclick=()=>{const t=draft.tasks.find(t=>t.id===el.dataset.ts);t.streak=!t.streak;el.classList.toggle('on');el.classList.toggle('off');el.textContent=t.streak?'🔥':'—';});
  ui.querySelectorAll('[data-tr]').forEach(el=>el.onclick=()=>{draft.tasks=draft.tasks.filter(t=>t.id!==el.dataset.tr);rebuildTasks();rebuildLevels();});
  initDrag(ui,draft.tasks,()=>{rebuildTasks();});
}
document.getElementById('addTaskBtn').onclick=()=>{const name=document.getElementById('ntName').value.trim();const type=document.getElementById('ntType').value;const xp=n(document.getElementById('ntXP').value)||1;const streak=document.getElementById('ntStreakTog').classList.contains('on');if(!name)return note('Введи название');draft.tasks.push({id:uid(),name,type,xp,streak});document.getElementById('ntName').value='';rebuildTasks();rebuildLevels();};

function rebuildLevels(){const thresholds=autoLevelThresholds(draft.tasks);const maxDay=calcMaxDailyXP(draft.tasks);const ui=document.getElementById('levelsUI');ui.innerHTML=draft.levelNames.map((l,i)=>`<div class="lv-edit-row"><input class="inp" value="${esc(l.name)}" data-ln="${l.id}"><input class="inp" type="color" value="${l.color}" data-lc="${l.id}"><div style="font-size:11px;color:var(--teal);white-space:nowrap">${thresholds[i]} XP</div></div>`).join('');ui.querySelectorAll('[data-ln]').forEach(el=>el.oninput=e=>{draft.levelNames.find(l=>l.id===el.dataset.ln).name=e.target.value;});ui.querySelectorAll('[data-lc]').forEach(el=>el.oninput=e=>{draft.levelNames.find(l=>l.id===el.dataset.lc).color=e.target.value;});document.getElementById('lvHint').textContent=`Макс. XP в день: ${maxDay}. Пороги пересчитываются автоматически.`;}

document.getElementById('resetBtn').onclick=()=>{if(!confirm('Сбросить все данные?'))return;S=DEFAULTS();pruneEntries();save();render();closeSet();};

// ── INIT ───────────────────────────────────────────────────────────────────
pruneEntries();
if(!userCode){showActivation();}else{render();}
</script>
</body>
</html>
