const DAY=86400000;
const toISO=d=>d.toISOString().split('T')[0];
const today=()=>toISO(new Date());
const uid=()=>Math.random().toString(36).slice(2,9);
const n=v=>Number(v)||0;
const clamp=(v,a,b)=>Math.max(a,Math.min(b,v));
const esc=s=>String(s||'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]));
function dRange(from,to){const out=[],s=new Date(from+'T12:00:00'),e=new Date(to+'T12:00:00');for(let d=new Date(s);d<=e;d=new Date(d.getTime()+DAY))out.push(toISO(d));return out;}
const wdShort=iso=>new Date(iso+'T12:00:00').toLocaleDateString('ru-RU',{weekday:'short'}).slice(0,2).toUpperCase();
const dtShort=iso=>new Date(iso+'T12:00:00').toLocaleDateString('ru-RU',{day:'numeric',month:'short'});
function hexAlpha(hex,a){const h=hex.replace('#','');const hh=h.length===3?h.split('').map(x=>x+x).join(''):h;return`rgba(${parseInt(hh.slice(0,2),16)},${parseInt(hh.slice(2,4),16)},${parseInt(hh.slice(4,6),16)},${a})`;}
function ring(pct,color,sz=44){const r=16,c=2*Math.PI*r,off=c-(c*clamp(pct,0,100)/100);return`<svg width="${sz}" height="${sz}" viewBox="0 0 40 40"><circle cx="20" cy="20" r="${r}" fill="none" stroke="rgba(255,255,255,.07)" stroke-width="5"/><circle cx="20" cy="20" r="${r}" fill="none" stroke="${color}" stroke-width="5" stroke-linecap="round" stroke-dasharray="${c.toFixed(1)}" stroke-dashoffset="${off.toFixed(1)}" transform="rotate(-90 20 20)"/><text x="20" y="24" text-anchor="middle" fill="${color}" font-size="10" font-weight="700" font-family="Exo 2,sans-serif">${pct}</text></svg>`;}

