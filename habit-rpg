// ── XP & STATS ─────────────────────────────────────────────────────────────
function dayXP(iso){const e=S.entries[iso];if(!e)return 0;return S.tasks.reduce((sum,t)=>{const v=e[t.id];if(t.type==='checkbox')return sum+(v?n(t.xp):0);return sum+n(v)*n(t.xp);},0);}
function calcStreak(taskId=null){
  const start=S.challenge?.start||today();const endDay=S.challenge?.end&&S.challenge.end<today()?S.challenge.end:today();
  if(start>endDay)return 0;const days=dRange(start,endDay).reverse();let s=0;
  for(const d of days){if(taskId){ensureEntry(d);const task=S.tasks.find(t=>t.id===taskId);if(!task)break;const val=S.entries[d]?.[taskId];const ok=task.type==='checkbox'?Boolean(val):n(val)>0;if(ok)s++;else break;}else{if(dayXP(d)>=n(S.threshold))s++;else break;}}
  return s;
}
function totalStats(){
  const start=S.challenge?.start||today();const endDay=S.challenge?.end&&S.challenge.end<today()?S.challenge.end:today();
  const days=start<=endDay?dRange(start,endDay):[today()];let base=0,filled=0,missed=0;
  days.forEach(d=>{const x=dayXP(d);if(x>0){base+=x;filled++;}else if(d<today())missed++;});
  const streak=calcStreak();const bonus=[...S.streakRules].filter(r=>streak>=n(r.days)).sort((a,b)=>b.days-a.days)[0]?.bonus||0;
  return{base,filled,missed,penalty:missed*n(S.penalty),streak,bonus,total:Math.max(0,base+bonus-missed*n(S.penalty))};
}
function buildLevels(){const t=autoLevelThresholds(S.tasks);return S.levelNames.map((ln,i)=>({...ln,min:t[i]||0}));}
function currentLevel(total){const sorted=buildLevels();let cur=sorted[0];for(const l of sorted)if(total>=n(l.min))cur=l;const idx=sorted.findIndex(l=>l.id===cur.id);return{cur,next:sorted[idx+1]||null,all:sorted};}
function historyDays(){const start=S.challenge?.start||today();const endDay=S.challenge?.end&&S.challenge.end<today()?S.challenge.end:today();if(start>endDay)return[today()];return dRange(start,endDay);}

