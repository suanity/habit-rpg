async function supaUpsert(code,data){
  try{
    const r=await fetch(`${SUPA_URL}/rest/v1/user_data`,{
      method:'POST',
      headers:{...supaHeaders(),'Prefer':'resolution=merge-duplicates'},
      body:JSON.stringify({code,data,updated_at:new Date().toISOString()})
    });
    return r.ok;
  }catch{return false;}
}

