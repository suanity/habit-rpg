async function supaLoad(code){
  try{
    const r=await fetch(`${SUPA_URL}/rest/v1/user_data?code=eq.${encodeURIComponent(code)}&select=data`,{headers:supaHeaders()});
    if(!r.ok)return null;
    const rows=await r.json();
